}

// ================================================================
// QUESTION GENERATORS
// ================================================================
function r(a,b){return Math.floor(Math.random()*(b-a+1))+a;}
function rd1(a,b){return Math.round((Math.random()*(b-a)+a)*10)/10;}
function rd2(a,b){return Math.round((Math.random()*(b-a)+a)*100)/100;}
function pick(arr){return arr[Math.floor(Math.random()*arr.length)];}
function fmt(n){return Number.isInteger(n)?String(n):String(n).replace('.',',');}
function parseAns(s){return parseFloat(s.replace(',','.'));}

function genQ(typeId,subIdx,lv){
  let text='',ans=0,ans2=null,hint='',dual=false,allowDec=false;

  switch(typeId){
    case 'add_all_int':{
      const mx=[50,100,300,999][lv-1];
      const t=r(1,4);
      if(t===1){let a=r(1,mx),b=r(1,mx);text=`${a} + ${b}`;ans=a+b;}
      else if(t===2){let a=r(1,mx),b=r(1,mx),c=r(1,50);text=`${a} + ${b} + ${c}`;ans=a+b+c;}
      else if(t===3){let a=r(1,Math.min(mx,99)),b=r(1,Math.min(mx,99)),c=r(1,Math.min(mx,99));text=`${a} + ${b} + ${c}`;ans=a+b+c;}
      else{let a=r(1,mx),b=r(1,50);text=`${a} + ${b}`;ans=a+b;}
      break;}
    case 'add_all_dec':{
      allowDec=true;
      const t=r(1,3);
      const mx=[5,10,50,100][lv-1];
      if(t===1){let a=r(1,mx),b=rd1(0.1,9.9);text=`${a} + ${fmt(b)}`;ans=Math.round((a+b)*10)/10;}
      else if(t===2){let a=rd1(0.1,9.9),b=rd1(0.1,9.9);text=`${fmt(a)} + ${fmt(b)}`;ans=Math.round((a+b)*10)/10;}
      else{let a=rd2(0.01,9.99),b=rd2(0.01,9.99);text=`${fmt(a)} + ${fmt(b)}`;ans=Math.round((a+b)*100)/100;}
      break;}
    case 'add_2_int':{
      const mx=[9,99,999][subIdx];
      const lvMx=[Math.min(mx,9),Math.min(mx,50),Math.min(mx,300),mx][lv-1];
      let a=r(1,lvMx),b=r(1,lvMx);
      text=`${a} + ${b}`;ans=a+b;break;}
    case 'add_complement':{
      const tgt=[10,100,1000][subIdx];
      let a;
      if(tgt===10)a=r(1,9);
      else if(tgt===100){const m=[10,5,1,1][lv-1];a=r(m,100-m);if(lv===1)a=r(1,9)*10;else if(lv===2)a=r(1,19)*5;}
      else{if(lv===1)a=r(1,9)*100;else if(lv===2)a=r(1,19)*50;else a=r(10,990);}
      a=Math.max(1,Math.min(a,tgt-1));
      if(r(0,1)===0){text=`? + ${a} = ${tgt}`;}else{text=`${a} + ? = ${tgt}`;}
      ans=tgt-a;break;}
    case 'add_maison':{
      // Toutes les maisons (3 à 10) au hasard selon le niveau
      const allTgts=[3,4,5,6,7,8,9,10];
      // Niveau 1 : maisons 3-6 / Niveau 2 : 3-8 / Niveau 3 : 3-9 / Niveau 4 : 3-10
      const maxTgt=[6,8,9,10][lv-1];
      const availTgts=allTgts.filter(t=>t<=maxTgt);
      const tgt=pick(availTgts);
      const a=r(0,tgt);
      if(r(0,1)===0){text=`${a} + ? = ${tgt}`;ans=tgt-a;}
      else{text=`? + ${tgt-a} = ${tgt}`;ans=a;}
      break;}
    case 'add_mult10':{
      const mx=[5,10,20,50][lv-1];
      let a=r(1,mx)*10,b=r(1,mx)*10;
      text=`${a} + ${b}`;ans=a+b;break;}
    case 'add_mult5_10':{
      const mx=[4,8,16,30][lv-1];
      let a=r(1,mx)*5,b=r(1,mx)*5;
      text=`${a} + ${b}`;ans=a+b;break;}
    case 'add_fin9':{
      const mx=[10,20,50,100][lv-1];
      let a=r(1,mx),b=r(1,mx)*10-1;if(b<1)b=9;
      text=`${a} + ${b}`;ans=a+b;break;}
    case 'add_fin89':{
      const mx=[10,20,50,100][lv-1];
      let a=r(1,mx),b=r(1,mx)*10-r(1,2);if(b<1)b=8;
      text=`${a} + ${b}`;ans=a+b;break;}
    case 'add_3_int':{
      const mx=[9,99,999][subIdx];
      const m=[Math.min(mx,9),Math.min(mx,30),Math.min(mx,150),mx][lv-1];
      let a=r(1,m),b=r(1,m),c=r(1,m);
      text=`${a} + ${b} + ${c}`;ans=a+b+c;break;}
    case 'add_4_int':{
      const mx=[9,99,999][subIdx];
      const m=[Math.min(mx,9),Math.min(mx,20),Math.min(mx,75),mx][lv-1];
      let a=r(1,m),b=r(1,m),c=r(1,m),d=r(1,m);
      text=`${a} + ${b} + ${c} + ${d}`;ans=a+b+c+d;break;}
    case 'add_int_dec':{
      allowDec=true;
      const mx=[10,20,50,100][lv-1];
      let a=r(1,mx),b=rd1(0.1,9.9);
      text=`${a} + ${fmt(b)}`;ans=Math.round((a+b)*10)/10;break;}
    case 'add_dec_dec':{
      allowDec=true;
      if(lv===1){let a=rd1(0.1,4.9),b=rd1(0.1,4.9);text=`${fmt(a)} + ${fmt(b)}`;ans=Math.round((a+b)*10)/10;}
      else if(lv===2){let a=rd1(0.1,9.9),b=rd1(0.1,9.9);text=`${fmt(a)} + ${fmt(b)}`;ans=Math.round((a+b)*10)/10;}
      else if(lv===3){let a=rd2(0.01,9.99),b=rd2(0.01,9.99);text=`${fmt(a)} + ${fmt(b)}`;ans=Math.round((a+b)*100)/100;}
      else{let a=rd2(0.01,99.99),b=rd2(0.01,99.99);text=`${fmt(a)} + ${fmt(b)}`;ans=Math.round((a+b)*100)/100;}
      break;}

    case 'sub_all_int':{
      const mx=[20,100,500,999][lv-1];
      let a=r(2,mx),b=r(1,a);
      text=`${a} − ${b}`;ans=a-b;break;}
    case 'sub_all_dec':{
      allowDec=true;
      const mx=[10,20,50,100][lv-1];
      const t=r(1,3);
      if(t===1){let a=r(2,mx),b=rd1(0.1,Math.min(a-0.1,9.9));text=`${a} − ${fmt(b)}`;ans=Math.round((a-b)*10)/10;}
      else if(t===2){let a=rd1(0.2,9.9),b=rd1(0.1,a-0.05);if(b>=a)b=a-0.1;text=`${fmt(a)} − ${fmt(b)}`;ans=Math.round((a-b)*10)/10;}
      else{let a=rd2(0.05,9.99),b=rd2(0.01,a-0.01);text=`${fmt(a)} − ${fmt(b)}`;ans=Math.round((a-b)*100)/100;}
      break;}
    case 'sub_2_int':{
      const mx=[9,99,999][subIdx];
      const m=[Math.min(mx,9),Math.min(mx,50),Math.min(mx,300),mx][lv-1];
      let a=r(2,m),b=r(1,a);
      text=`${a} − ${b}`;ans=a-b;break;}
    case 'sub_mult10':{
      const mx=[5,10,20,50][lv-1];
      let b=r(1,mx)*10,a=b+r(1,mx)*10;
      text=`${a} − ${b}`;ans=a-b;break;}
    case 'sub_mult5_10':{
      const mx=[4,8,16,30][lv-1];
      let b=r(1,mx)*5,a=b+r(1,mx)*5;
      text=`${a} − ${b}`;ans=a-b;break;}
    case 'sub_fin9':{
      const mx=[10,20,50,100][lv-1];
      let b=r(1,mx)*10-1;if(b<1)b=9;
      let a=b+r(1,mx);
      text=`${a} − ${b}`;ans=a-b;break;}
    case 'sub_fin89':{
      const mx=[10,20,50,100][lv-1];
      let b=r(1,mx)*10-r(1,2);if(b<1)b=8;
      let a=b+r(1,mx);
      text=`${a} − ${b}`;ans=a-b;break;}
    case 'sub_3_int':{
      const mx=[9,99,999][subIdx];
      const m=[Math.min(mx,9),Math.min(mx,30),Math.min(mx,100),mx][lv-1];
      let a=r(4,m*2||10),b=r(1,Math.floor(a/3)),c=r(1,Math.floor(a/3));
      if(a-b-c<0)c=0;
      text=`${a} − ${b} − ${c}`;ans=a-b-c;break;}
    case 'sub_4_int':{
      const mx=[9,99,999][subIdx];
      const m=[Math.min(mx,9),Math.min(mx,20),Math.min(mx,50),mx][lv-1];
      let a=r(5,m*2||15),b=r(1,Math.floor(a/4)),c=r(1,Math.floor(a/4)),d=r(0,Math.floor(a/4));
      if(a-b-c-d<0)d=0;
      text=`${a} − ${b} − ${c} − ${d}`;ans=a-b-c-d;break;}
    case 'sub_int_dec':{
      allowDec=true;
      const mx=[10,20,50,100][lv-1];
      let b=rd1(0.1,Math.min(mx-1,9.9)),a=r(Math.ceil(b)+1,mx);
      text=`${a} − ${fmt(b)}`;ans=Math.round((a-b)*10)/10;break;}
    case 'sub_dec_dec':{
      allowDec=true;
      if(lv===1){let a=rd1(0.2,9.9),b=rd1(0.1,a-0.1);if(b<0.1)b=0.1;text=`${fmt(a)} − ${fmt(b)}`;ans=Math.round((a-b)*10)/10;}
      else if(lv===2){let a=rd1(1,9.9),b=rd1(0.1,a-0.1);text=`${fmt(a)} − ${fmt(b)}`;ans=Math.round((a-b)*10)/10;}
      else if(lv===3){let a=rd2(0.5,9.99),b=rd2(0.1,a-0.01);text=`${fmt(a)} − ${fmt(b)}`;ans=Math.round((a-b)*100)/100;}
      else{let a=rd2(1,99.99),b=rd2(0.01,a-0.01);text=`${fmt(a)} − ${fmt(b)}`;ans=Math.round((a-b)*100)/100;}
      break;}

    case 'mul_all_int':{
      const [mn,mx]=[[2,5],[2,9],[2,12],[3,25]][lv-1];
      let a=r(mn,mx),b=r(mn,mx);
      text=`${a} × ${b}`;ans=a*b;break;}
    case 'mul_all_dec':{
      allowDec=true;
      const mx=[5,9,12,20][lv-1];
      if(lv<=2){let a=r(2,mx),b=rd1(0.1,9.9);text=`${a} × ${fmt(b)}`;ans=Math.round(a*b*10)/10;}
      else{let a=r(2,mx),b=rd2(0.1,9.9);text=`${a} × ${fmt(b)}`;ans=Math.round(a*b*100)/100;}
      break;}
    case 'mul_tables':{
      const tableN=subIdx<8?subIdx+2:r(2,9);
      const mx=[5,7,9,10][lv-1];
      let b=r(1,mx);
      text=r(0,1)===0?`${tableN} × ${b}`:`${b} × ${tableN}`;
      ans=tableN*b;break;}
    case 'mul_10_100':{
      allowDec=true;
      const muls=[10,100,1000,pick([10,100,1000])];
      const m=muls[subIdx];
      const mx=[99,999,999,999][lv-1];
      let a=lv<=2?r(1,mx):rd1(0.1,mx);
      text=`${fmt(a)} × ${m}`;ans=Math.round(parseFloat(a)*m*100)/100;break;}
    case 'mul_par2':{
      const mx=[10,25,50,100][lv-1];
      let a=r(1,mx);text=`${a} × 2`;ans=a*2;break;}
    case 'mul_par4':{
      const mx=[10,25,50,100][lv-1];
      let a=r(1,mx);text=`${a} × 4`;ans=a*4;break;}
    case 'mul_dec_int':{
      allowDec=true;
      const mx=[5,9,12,20][lv-1];
      let a=rd1(0.1,9.9),b=r(2,mx);
      text=`${fmt(a)} × ${b}`;ans=Math.round(a*b*10)/10;break;}

    case 'div_all_int':{
      const [mn,mx]=[[2,5],[2,9],[2,12],[2,12]][lv-1];
      const mxQ=[5,9,12,20][lv-1];
      let d=r(mn,mx),q=r(1,mxQ);
      text=`${d*q} ÷ ${d}`;ans=q;break;}
    case 'div_all_dec':{
      allowDec=true;
      if(lv===1){let d=pick([2,4,5]),q=r(1,9);text=`${d*q} ÷ ${d}`;ans=q;}
      else if(lv===2){let d=pick([2,4,5,10]),a=r(1,5)*d+r(1,d-1);text=`${a} ÷ ${d}`;ans=Math.round(a/d*10)/10;}
      else if(lv===3){let d=pick([2,4,5,10]),a=r(1,20)*d+r(0,d-1);text=`${a} ÷ ${d}`;ans=Math.round(a/d*100)/100;}
      else{let d=pick([2,3,4,5,6,8]),a=r(1,50)*d+r(0,d-1);text=`${a} ÷ ${d}`;ans=Math.round(a/d*100)/100;}
      break;}
    case 'div_pair_2':{
      const mx=[10,20,50,100][lv-1];
      let q=r(1,mx);text=`${q*2} ÷ 2`;ans=q;break;}
    case 'div_impair_2':{
      allowDec=true;
      const mx=[10,20,50,100][lv-1];
      let a=r(1,mx*2);text=`${a} ÷ 2`;ans=a/2;break;}
    case 'div_248_ent':{
      const dArr=[[2],[2,4],[2,4,8],[2,4,8]][lv-1];
      const d=pick(dArr),mx=[5,10,20,50][lv-1];
      let q=r(1,mx);text=`${q*d} ÷ ${d}`;ans=q;break;}
    case 'div_248_dec':{
      allowDec=true;
      const dArr=[[2],[2,4],[2,4,8],[2,4,8]][lv-1];
      const d=pick(dArr),mx=[10,20,50,100][lv-1];
      let a=r(1,mx);text=`${a} ÷ ${d}`;ans=Math.round(a/d*100)/100;break;}
    case 'div_quot_rest':{
      dual=true;
      const [mn,mx]=[[2,5],[2,9],[2,9],[3,12]][lv-1];
      const mxN=[20,50,100,200][lv-1];
      let d=r(mn,mx),n=r(d+1,mxN);
      let q=Math.floor(n/d),rest=n%d;
      text=`${n} ÷ ${d}`;ans=q;ans2=rest;
      hint='Quotient et reste';break;}
    default: text='1 + 1';ans=2;
  }

  return {text:text+' = ?', answer:ans, answer2:ans2, hint, isDual:dual, allowDec};
}

// ================================================================
// GAME
// ================================================================
function startGame(){
  if(!selCat||!selTypeId){alert('Choisis une opération et un type !');nav(1,'back');return;}
  if(!selLevel){alert('Choisis un niveau de difficulté !');nav(3,'fwd');return;}
  questions=[];
  for(let i=0;i<nbQ;i++)questions.push(genQ(selTypeId,selSubIdx,selLevel));
  curQ=0;score=0;answers=[];answered=false;

  const lvNames={1:'Débutant',2:'Intermédiaire',3:'Confirmé',4:'Expert'};
  document.getElementById('gCatLabel').textContent=CAT_NAMES[selCat];
  document.getElementById('gLvLabel').textContent=lvNames[selLevel];
  document.getElementById('gQTotal').textContent=nbQ;
  nav(4,'fwd');
  setTimeout(showQuestion,300);
}

function showQuestion(){
  if(curQ>=nbQ){endGame();return;}
  answered=false;
  const q=questions[curQ];
  isDual=q.isDual;

  document.getElementById('qLabel').textContent=`Question ${curQ+1}`;
  document.getElementById('qText').textContent=q.text;
  document.getElementById('qHint').textContent=q.hint||'';
  document.getElementById('gQNum').textContent=curQ+1;
  document.getElementById('gScore').textContent=score;
  document.getElementById('progressFill').style.width=(curQ/nbQ*100)+'%';

  document.getElementById('normalAnswer').style.display=isDual?'none':'block';
  document.getElementById('dualAnswer').style.display=isDual?'grid':'none';
  document.getElementById('activeInputLabel').style.display=isDual?'block':'none';

  const dotBtn=document.getElementById('dotBtn');
  const tabBtn=document.getElementById('tabBtn');
  if(isDual){dotBtn.style.display='none';tabBtn.style.display='block';}
  else{dotBtn.style.display=q.allowDec?'block':'none';tabBtn.style.display='none';}

  if(isDual){
    document.getElementById('ansQ').value='';document.getElementById('ansR').value='';
    document.getElementById('ansQ').className='answer-input';document.getElementById('ansR').className='answer-input';
    dualFocus='q';updateDualLabel();
    setTimeout(()=>document.getElementById('ansQ').focus(),80);
  }else{
    const inp=document.getElementById('answerInput');
    inp.value='';inp.className='answer-input';
    setTimeout(()=>inp.focus(),80);
  }
  bStart();startCountdown();
}

function updateDualLabel(){
  document.getElementById('activeInputLabel').textContent=dualFocus==='q'?'Saisie : Quotient':'Saisie : Reste';
}

function startCountdown(){
  clearInterval(timer);timeLeft=timePerQ;updateTimerUI(timeLeft,timePerQ);
  timer=setInterval(()=>{
    timeLeft--;updateTimerUI(timeLeft,timePerQ);
    if(timeLeft<=3&&timeLeft>0)bTick();
    if(timeLeft<=0){clearInterval(timer);bEnd();if(!answered){recordAns(null,false,true);nextQ();}}
  },1000);
}

function updateTimerUI(t,total){
  document.getElementById('timerText').textContent=t;
  const arc=document.getElementById('timerArc');
  const frac=t/total;
  arc.style.strokeDashoffset=CIRC*(1-frac);
  arc.style.stroke=frac>0.5?'var(--accent4)':frac>0.25?'var(--accent2)':'var(--accent1)';
}

function handleKey(e){if(e.key==='Enter')submitAnswer();}
function handleKeyDual(e,field){
  if(e.key==='Enter'||e.key==='Tab'){
    e.preventDefault();
    if(field==='q'){dualFocus='r';updateDualLabel();document.getElementById('ansR').focus();}
    else submitAnswer();
  }
}

function np(k){
  const inp=isDual?document.getElementById(dualFocus==='q'?'ansQ':'ansR'):document.getElementById('answerInput');
  if(k==='del')inp.value=inp.value.slice(0,-1);
  else if(k==='-')inp.value=inp.value.startsWith('-')?inp.value.slice(1):'-'+inp.value;
  else if(k==='tab'){
    if(isDual){dualFocus=dualFocus==='q'?'r':'q';updateDualLabel();document.getElementById(dualFocus==='q'?'ansQ':'ansR').focus();}
  }
  else if(inp.value.length<10)inp.value+=k;
}

function submitAnswer(){
  if(answered)return;
  const q=questions[curQ];
  if(isDual){
    const vq=document.getElementById('ansQ').value.trim();
    const vr=document.getElementById('ansR').value.trim();
    if(vq===''||vr==='')return;
    clearInterval(timer);answered=true;
    const gq=parseInt(vq,10),gr=parseInt(vr,10);
    const ok=(gq===q.answer)&&(gr===q.answer2);
    document.getElementById('ansQ').className='answer-input '+(gq===q.answer?'correct':'wrong');
    document.getElementById('ansR').className='answer-input '+(gr===q.answer2?'correct':'wrong');
    if(ok){score++;bOk();showFb('✅');}else{bWrong();showFb('❌');}
    recordAns(vq+' / '+vr,ok,false);
    setTimeout(nextQ,950);
  }else{
    const v=document.getElementById('answerInput').value.trim();
    if(v==='')return;
    clearInterval(timer);answered=true;
    const given=parseAns(v);
    const ok=Math.abs(given-q.answer)<0.001;
    const inp=document.getElementById('answerInput');
    if(ok){inp.className='answer-input correct';score++;bOk();showFb('✅');}
    else{inp.className='answer-input wrong';bWrong();showFb('❌');}
    recordAns(v,ok,false);
    setTimeout(nextQ,950);
  }
}

function recordAns(given,ok,skipped){
  answers.push({q:questions[curQ].text,ans:questions[curQ].answer,ans2:questions[curQ].answer2,given,ok,skipped,isDual:questions[curQ].isDual});
}

function nextQ(){curQ++;if(curQ>=nbQ)endGame();else showQuestion();}

function endGame(){
  clearInterval(timer);nav(5,'fwd');
  const total=nbQ,correct=answers.filter(a=>a.ok).length;
  const wrong=answers.filter(a=>!a.ok&&!a.skipped).length;
  const skip=answers.filter(a=>a.skipped).length;
  const pct=Math.round(correct/total*100);
  document.getElementById('resScore').textContent=correct;
  document.getElementById('resLabel').textContent=`sur ${total} — ${pct>=80?'Bravo !':pct>=60?'Bien !':pct>=40?'Continue !':'Courage !'}`;
  document.getElementById('stCorrect').textContent=correct;
  document.getElementById('stWrong').textContent=wrong;
  document.getElementById('stSkip').textContent=skip;
  document.getElementById('stPct').textContent=pct+'%';
  document.getElementById('resEmoji').textContent=pct===100?'🏆':pct>=80?'🎉':pct>=60?'👍':pct>=40?'😊':'😅';
  const list=document.getElementById('reviewList');
  list.innerHTML='';
  answers.forEach(a=>{
    const div=document.createElement('div');
    div.className='review-item';
    const givenStr=a.skipped?'—':a.given;
    const correctStr=a.isDual?`${a.ans} r.${a.ans2}`:`${fmt(a.ans)}`;
    const cls=a.ok?'correct-a':'wrong-a';
    div.innerHTML=`<span class="review-q">${a.q}</span><span class="review-given ${cls}">${givenStr}</span>${!a.ok?`<span class="review-ans">→ ${correctStr}</span>`:''}<span class="review-icon">${a.ok?'✅':a.skipped?'⏱':'❌'}</span>`;
    list.appendChild(div);
  });
}

function quitGame(){
  if(confirm('Quitter la partie ?')){clearInterval(timer);nav(1,'back');}
}
function showFb(txt){
  const el=document.getElementById('feedbackPop');
  el.textContent=txt;el.className='feedback-pop show';
  setTimeout(()=>{el.className='feedback-pop hide';},680);
}

// Init defaults
setTime(10);setNbQ(10);
document.addEventListener('keydown',e=>{
  if(e.key==='Enter'&&document.getElementById('s4').classList.contains('active')&&!answered)submitAnswer();
});
