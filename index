// ================================================================
// AUDIO
// ================================================================
let actx=null;
function getAC(){if(!actx)actx=new(window.AudioContext||window.webkitAudioContext)();return actx;}
function beep(f,d,type='sine',v=0.32){
  try{const a=getAC();const o=a.createOscillator();const g=a.createGain();
  o.connect(g);g.connect(a.destination);o.type=type;o.frequency.value=f;
  g.gain.setValueAtTime(v,a.currentTime);g.gain.exponentialRampToValueAtTime(0.001,a.currentTime+d);
  o.start();o.stop(a.currentTime+d);}catch(e){}}
const bStart=()=>{beep(880,0.1);setTimeout(()=>beep(1047,0.12),120);}
const bEnd=()=>{beep(523,0.07,'square',0.18);setTimeout(()=>beep(392,0.07,'square',0.18),90);setTimeout(()=>beep(330,0.18,'square',0.14),180);}
const bOk=()=>{beep(1047,0.06);setTimeout(()=>beep(1319,0.13),65);}
const bWrong=()=>beep(220,0.18,'sawtooth',0.18);
const bTick=()=>beep(660,0.04,'sine',0.1);

// ================================================================
// NAVIGATION
// ================================================================
function nav(screenNum, dir='fwd') {
  document.querySelectorAll('.screen').forEach(s=>{s.classList.remove('active','anim-fwd','anim-back');});
  const s=document.getElementById('s'+screenNum);
  s.classList.add('active', dir==='back'?'anim-back':'anim-fwd');
  window.scrollTo(0,0);
}

// ================================================================
// SCREEN 1 → 2 : select category
// ================================================================
function selectCat(cat) {
  selCat=cat; selTypeId=null; selSubIdx=0;
  document.body.className='cat-'+cat;

  // update badge
  document.getElementById('catBadgeIcon').textContent=CAT_ICONS[cat];
  document.getElementById('catBadgeName').textContent=CAT_NAMES[cat];
  document.getElementById('catBadge').style.setProperty('--clr-active','var(--'+cat+')');

  // render types grid
  renderTypeGrid(cat);
  nav(2,'fwd');
}

function renderTypeGrid(cat) {
  const grid=document.getElementById('typeGrid');
  grid.innerHTML='';
  TYPES[cat].forEach(t=>{
    const div=document.createElement('div');
    div.className='type-card';
    div.dataset.tid=t.id;
    const nameEl=document.createElement('div');
    nameEl.className='type-card-name';
    // flatten name (no line breaks in display)
    nameEl.textContent=t.name.replace(/\n/g,' ');
    div.appendChild(nameEl);
    div.onclick=()=>selectType(t.id);
    grid.appendChild(div);
  });
}

function selectType(tid) {
  selTypeId=tid; selSubIdx=0;
  document.querySelectorAll('.type-card').forEach(el=>{
    el.classList.toggle('selected',el.dataset.tid===tid);
  });
  const t=TYPES[selCat].find(x=>x.id===tid);
  if(t && t.sub && t.sub.length>0){
    showSubModal(t);
  } else {
    setTimeout(()=>nav(3,'fwd'),140);
  }
}

function showSubModal(t){
  const old=document.getElementById('subModal');
  if(old)old.remove();
  const modal=document.createElement('div');
  modal.id='subModal';
  modal.style.cssText='position:fixed;inset:0;background:rgba(0,0,0,0.72);display:flex;align-items:center;justify-content:center;z-index:200;padding:20px;';
  const box=document.createElement('div');
  box.style.cssText='background:var(--card);border-radius:20px;padding:22px 18px;width:100%;max-width:360px;border:2px solid var(--clr-active,var(--accent4));';
  const title=document.createElement('div');
  title.style.cssText='font-size:0.7rem;font-weight:800;text-transform:uppercase;letter-spacing:2px;color:var(--muted);margin-bottom:14px;';
  title.textContent='Choisir la variante';
  box.appendChild(title);
  const grid=document.createElement('div');
  grid.style.cssText='display:flex;flex-wrap:wrap;gap:8px;';
  t.sub.forEach((s,i)=>{
    const btn=document.createElement('button');
    btn.style.cssText='padding:10px 16px;border-radius:50px;border:2px solid var(--surface);background:var(--surface);color:var(--text);font-family:Nunito,sans-serif;font-size:0.88rem;font-weight:700;cursor:pointer;';
    btn.textContent=s;
    btn.onclick=()=>{selSubIdx=i;modal.remove();setTimeout(()=>nav(3,'fwd'),100);};
    grid.appendChild(btn);
  });
  box.appendChild(grid);
  const cancel=document.createElement('button');
  cancel.style.cssText='margin-top:14px;width:100%;padding:10px;border-radius:50px;border:none;background:var(--surface);color:var(--muted);font-family:Nunito,sans-serif;font-size:0.85rem;font-weight:700;cursor:pointer;';
  cancel.textContent='← Annuler';
  cancel.onclick=()=>modal.remove();
  box.appendChild(cancel);
  modal.appendChild(box);
  modal.onclick=(e)=>{if(e.target===modal)modal.remove();};
  document.body.appendChild(modal);
}

// ================================================================
// SCREEN 3 : level + settings
// ================================================================
function selectLevel(lv){
