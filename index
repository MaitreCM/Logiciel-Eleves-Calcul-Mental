<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Calcul Mental</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Fredoka+One&display=swap');

:root {
  --bg: #0f0e17;
  --surface: #1a1929;
  --card: #232236;
  --card2: #2a293f;
  --accent1: #ff6b6b;
  --accent2: #ffd93d;
  --accent3: #6bcb77;
  --accent4: #4d96ff;
  --text: #fffffe;
  --muted: #a7a9be;
  --add: #6bcb77;
  --sub: #ff6b6b;
  --mul: #ffd93d;
  --div: #4d96ff;
}

* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

html, body {
  height: 100%;
}

body {
  font-family: 'Nunito', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow-x: hidden;
}

/* ===== SCREENS ===== */
.screen {
  display: none;
  width: 100%;
  max-width: 680px;
  min-height: 100vh;
  flex-direction: column;
  align-items: center;
  padding: 20px 14px 24px;
}
.screen.active { display: flex; }
@keyframes fadeIn { from { opacity: 0; transform: translateX(18px); } to { opacity: 1; transform: none; } }
@keyframes fadeBack { from { opacity: 0; transform: translateX(-18px); } to { opacity: 1; transform: none; } }
.screen.anim-fwd { animation: fadeIn 0.22s ease; }
.screen.anim-back { animation: fadeBack 0.22s ease; }

.app-title {
  font-family: 'Fredoka One', cursive;
  font-size: clamp(1.7rem, 5.5vw, 2.6rem);
  text-align: center;
  background: linear-gradient(135deg, var(--accent2), var(--accent1));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 4px;
}
.app-sub {
  color: var(--muted);
  font-size: 0.82rem;
  text-align: center;
  margin-bottom: 20px;
}
.section-lbl {
  font-size: 0.7rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--muted);
  margin-bottom: 12px;
  width: 100%;
}
.btn-back {
  align-self: flex-start;
  background: none;
  border: none;
  color: var(--muted);
  font-family: 'Nunito', sans-serif;
  font-size: 0.88rem;
  font-weight: 700;
  cursor: pointer;
  padding: 2px 0;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 5px;
}
.btn-back:hover { color: var(--text); }

/* ========== SCREEN 1: CATEGORIES ========== */
#s1 {
  justify-content: center;
}
#s1 .cat-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
  width: 100%;
  max-width: 360px;
  margin-top: 8px;
}

.cat-card {
  background: var(--card);
  border-radius: 22px;
  padding: 28px 10px 22px;
  text-align: center;
  cursor: pointer;
  border: 2.5px solid transparent;
  transition: all 0.18s ease;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  aspect-ratio: 1;
  justify-content: center;
}
.cat-card:hover { transform: translateY(-4px); }
.cat-card[data-cat="add"] { --clr: var(--add); }
.cat-card[data-cat="sub"] { --clr: var(--sub); }
.cat-card[data-cat="mul"] { --clr: var(--mul); }
.cat-card[data-cat="div"] { --clr: var(--div); }
.cat-card .cat-icon { font-size: 3.4rem; line-height: 1; }
.cat-card .cat-name { font-size: 1rem; font-weight: 800; color: var(--clr); }
.cat-card .cat-count { font-size: 0.7rem; color: var(--muted); }

/* ========== SCREEN 2: TYPES (2 colonnes, sans scroll) ========== */
#s2 {
  justify-content: flex-start;
}

/* Header with cat badge */
.cat-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--card);
  border-radius: 50px;
  padding: 6px 16px 6px 10px;
  margin-bottom: 14px;
  border: 2px solid var(--clr-active, var(--accent4));
}
.cat-badge-icon { font-size: 1.2rem; }
.cat-badge-name { font-size: 0.85rem; font-weight: 800; color: var(--clr-active, var(--accent4)); }

/* 2-column grid of type cards — auto height, no scroll */
.type-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 7px;
  width: 100%;
}

.type-card {
  background: var(--card);
  border-radius: 10px;
  padding: 8px 11px;
  cursor: pointer;
  border: 2px solid transparent;
  transition: all 0.13s;
  display: flex;
  align-items: center;
}
.type-card:hover { background: var(--card2); }
.type-card.selected {
  border-color: var(--clr-active, var(--accent4));
  background: var(--card2);
}
.type-card-name {
  font-size: 0.75rem;
  font-weight: 700;
  line-height: 1.3;
  color: var(--text);
}
.type-card.selected .type-card-name { color: var(--clr-active, var(--accent4)); }

/* ========== SCREEN 3: LEVEL + SETTINGS ========== */
.level-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
  width: 100%;
  margin-bottom: 20px;
}
.lvl-card {
  background: var(--card);
  border-radius: 14px;
  padding: 12px 6px;
  text-align: center;
  cursor: pointer;
  border: 2.5px solid transparent;
  transition: all 0.14s;
}
.lvl-card:hover { transform: translateY(-2px); }
.lvl-card[data-lv="1"] { --clr: var(--accent3); }
.lvl-card[data-lv="2"] { --clr: var(--accent4); }
.lvl-card[data-lv="3"] { --clr: var(--accent2); }
.lvl-card[data-lv="4"] { --clr: var(--accent1); }
.lvl-card.selected { border-color: var(--clr); box-shadow: 0 0 0 3px color-mix(in srgb, var(--clr) 18%, transparent); }
.lvl-icon { font-size: 1.5rem; margin-bottom: 3px; }
.lvl-name { font-size: 0.65rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.3px; color: var(--clr); }

.settings-box {
  background: var(--card);
  border-radius: 16px;
  padding: 16px 18px;
  width: 100%;
  margin-bottom: 16px;
}
.settings-row { margin-bottom: 14px; }
.settings-row:last-child { margin-bottom: 0; }
.settings-label {
  font-size: 0.72rem;
  font-weight: 800;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 8px;
}
.chip-row { display: flex; gap: 6px; flex-wrap: wrap; }
.chip-btn {
  padding: 7px 12px;
  border-radius: 50px;
  border: 2px solid transparent;
  background: var(--surface);
  color: var(--text);
  font-family: 'Nunito', sans-serif;
  font-size: 0.82rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.13s;
}
.chip-btn:hover { background: var(--card2); }
.chip-btn.selected { border-color: var(--accent2); color: var(--accent2); }
.custom-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 8px;
}
.custom-row label { font-size: 0.78rem; color: var(--muted); white-space: nowrap; }
.custom-row input {
  width: 64px;
  padding: 6px 8px;
  border-radius: 8px;
  border: 2px solid var(--surface);
  background: var(--surface);
  color: var(--text);
  font-family: 'Nunito', sans-serif;
  font-size: 0.9rem;
  font-weight: 700;
  text-align: center;
  outline: none;
  transition: border-color 0.2s;
}
.custom-row input:focus { border-color: var(--accent2); }

/* ========== BUTTONS ========== */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 13px 28px;
  border-radius: 50px;
  border: none;
  font-family: 'Nunito', sans-serif;
  font-size: 1rem;
  font-weight: 800;
  cursor: pointer;
  transition: all 0.18s ease;
}
.btn-primary {
  background: linear-gradient(135deg, var(--accent1), var(--accent2));
  color: #1a0a00;
  width: 100%;
  padding: 15px 32px;
  font-size: 1.05rem;
}
.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(255,107,107,0.28); }
.btn-primary:active { transform: scale(0.97); }
.btn-secondary {
  background: var(--card);
  color: var(--muted);
  border: 2px solid var(--surface);
  font-size: 0.88rem;
}
.btn-secondary:hover { color: var(--text); border-color: var(--muted); }

/* ========== GAME SCREEN ========== */
.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  margin-bottom: 12px;
  gap: 6px;
  flex-wrap: wrap;
}
.g-chip {
  background: var(--card);
  border-radius: 50px;
  padding: 5px 12px;
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--muted);
}
.g-chip span { color: var(--text); }
.progress-bar {
  width: 100%;
  height: 5px;
  background: var(--surface);
  border-radius: 99px;
  overflow: hidden;
  margin-bottom: 16px;
}
.progress-fill {
  height: 100%;
  border-radius: 99px;
  background: linear-gradient(90deg, var(--accent4), var(--accent3));
  transition: width 0.4s ease;
}
.timer-wrap {
  position: relative;
  width: 96px; height: 96px;
  margin: 0 auto 18px;
}
.timer-svg { transform: rotate(-90deg); }
.timer-bg { fill: none; stroke: var(--surface); stroke-width: 7; }
.timer-arc { fill: none; stroke-width: 7; stroke-linecap: round; transition: stroke 0.3s; }
.timer-text {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Fredoka One', cursive;
  font-size: 2rem;
}
.question-card {
  background: var(--card);
  border-radius: 20px;
  padding: 26px 18px;
  text-align: center;
  width: 100%;
  margin-bottom: 16px;
  min-height: 110px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.question-label {
  font-size: 0.68rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--muted);
  margin-bottom: 8px;
}
.question-text {
  font-family: 'Fredoka One', cursive;
  font-size: clamp(1.7rem, 7vw, 3rem);
  line-height: 1.15;
}
.question-hint { font-size: 0.78rem; color: var(--muted); margin-top: 7px; }

.answer-wrap { width: 100%; margin-bottom: 12px; }
.answer-input {
  width: 100%;
  padding: 15px 16px;
  border-radius: 12px;
  border: 2.5px solid var(--surface);
  background: var(--card);
  color: var(--text);
  font-family: 'Fredoka One', cursive;
  font-size: 1.9rem;
  text-align: center;
  outline: none;
  transition: border-color 0.2s;
  -webkit-appearance: none;
}
.answer-input:focus { border-color: var(--accent4); }
.answer-input.correct { border-color: var(--accent3); background: color-mix(in srgb, var(--accent3) 10%, var(--card)); }
.answer-input.wrong { border-color: var(--accent1); background: color-mix(in srgb, var(--accent1) 10%, var(--card)); animation: shake 0.3s; }
@keyframes shake { 0%,100%{transform:translateX(0)} 25%{transform:translateX(-7px)} 75%{transform:translateX(7px)} }

.dual-answer {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  width: 100%;
  margin-bottom: 12px;
}
.dual-answer .answer-input { font-size: 1.5rem; }
.dual-label { font-size: 0.68rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); text-align: center; margin-bottom: 3px; }

/* Numpad */
.numpad {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 7px;
  width: 100%;
  margin-bottom: 10px;
}
.np-btn {
  padding: 13px;
  border-radius: 11px;
  border: none;
  background: var(--card);
  color: var(--text);
  font-family: 'Fredoka One', cursive;
  font-size: 1.4rem;
  cursor: pointer;
  transition: all 0.11s;
}
.np-btn:active { transform: scale(0.9); background: var(--surface); }
.np-btn.sp { background: var(--surface); font-size: 0.88rem; color: var(--muted); font-family: 'Nunito', sans-serif; font-weight: 700; }
.np-btn.ok { background: linear-gradient(135deg, var(--accent4), var(--accent3)); color: #001a00; font-family: 'Nunito', sans-serif; font-weight: 800; font-size: 0.92rem; grid-column: span 3; padding: 14px; }
.active-input-label { font-size: 0.68rem; color: var(--accent2); text-align: center; margin-bottom: 5px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; }

@media (min-width: 480px) {
  .numpad { display: none; }
  .active-input-label { display: none; }
  .answer-input { pointer-events: auto; }
}
@media (max-width: 479px) {
  .answer-input { pointer-events: none; caret-color: transparent; }
}

/* Results */
.result-hero { text-align: center; margin: 10px 0 18px; }
.result-emoji { font-size: 3.2rem; }
.result-score { font-family: 'Fredoka One', cursive; font-size: clamp(3rem, 11vw, 5.5rem); line-height: 1; }
.result-label { font-size: 0.95rem; color: var(--muted); margin-top: 3px; }
.stats-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; width: 100%; margin-bottom: 18px; }
@media (min-width: 440px) { .stats-grid { grid-template-columns: repeat(4, 1fr); } }
.stat-card { background: var(--card); border-radius: 12px; padding: 12px 8px; text-align: center; }
.stat-val { font-size: 1.6rem; font-weight: 800; }
.stat-lbl { font-size: 0.65rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.8px; margin-top: 2px; }
.review-list { width: 100%; display: flex; flex-direction: column; gap: 5px; margin-bottom: 18px; max-height: 280px; overflow-y: auto; }
.review-item { display: flex; align-items: center; justify-content: space-between; background: var(--card); border-radius: 9px; padding: 9px 13px; font-size: 0.88rem; gap: 8px; }
.review-q { font-weight: 700; flex: 1; }
.review-given { font-weight: 800; }
.correct-a { color: var(--accent3); }
.wrong-a { color: var(--accent1); text-decoration: line-through; }
.review-ans { color: var(--accent3); font-size: 0.78rem; }
.review-icon { font-size: 1rem; flex-shrink: 0; }
.btn-row { display: flex; gap: 10px; width: 100%; }
.btn-row .btn { flex: 1; }

/* Feedback */
.feedback-pop {
  position: fixed; top: 40%; left: 50%;
  transform: translate(-50%,-50%) scale(0);
  font-size: 4.5rem;
  pointer-events: none; z-index: 99;
  transition: transform 0.14s, opacity 0.28s;
  opacity: 0;
}
.feedback-pop.show { transform: translate(-50%,-60%) scale(1); opacity: 1; }
.feedback-pop.hide { transform: translate(-50%,-80%) scale(0.8); opacity: 0; }

body.cat-add { --clr-active: var(--add); }
body.cat-sub { --clr-active: var(--sub); }
body.cat-mul { --clr-active: var(--mul); }
body.cat-div { --clr-active: var(--div); }
</style>
</head>
<body>

<div class="feedback-pop" id="feedbackPop"></div>

<!-- ====================================================
     ÉCRAN 1 : CHOIX DE L'OPÉRATION
===================================================== -->
<div class="screen active" id="s1">
  <div class="app-title">🧮 Calcul Mental</div>
  <p class="app-sub">Choisis une opération</p>

  <div class="cat-grid">
    <div class="cat-card" data-cat="add" onclick="selectCat('add')">
      <span class="cat-icon">➕</span>
      <div class="cat-name">Addition</div>
      <div class="cat-count">13 types</div>
    </div>
    <div class="cat-card" data-cat="sub" onclick="selectCat('sub')">
      <span class="cat-icon">➖</span>
      <div class="cat-name">Soustraction</div>
      <div class="cat-count">11 types</div>
    </div>
    <div class="cat-card" data-cat="mul" onclick="selectCat('mul')">
      <span class="cat-icon">✖️</span>
      <div class="cat-name">Multiplication</div>
      <div class="cat-count">7 types</div>
    </div>
    <div class="cat-card" data-cat="div" onclick="selectCat('div')">
      <span class="cat-icon">➗</span>
      <div class="cat-name">Division</div>
      <div class="cat-count">7 types</div>
    </div>
  </div>
</div>

<!-- ====================================================
     ÉCRAN 2 : CHOIX DU TYPE (2 colonnes)
===================================================== -->
<div class="screen" id="s2">
  <button class="btn-back" onclick="nav(1,'back')">← Retour</button>
  <div class="cat-badge" id="catBadge">
    <span class="cat-badge-icon" id="catBadgeIcon">➕</span>
    <span class="cat-badge-name" id="catBadgeName">Addition</span>
  </div>
  <div class="section-lbl">Choisis le type de calcul</div>
  <div class="type-grid" id="typeGrid"></div>
</div>

<!-- ====================================================
     ÉCRAN 3 : NIVEAU + RÉGLAGES
===================================================== -->
<div class="screen" id="s3">
  <button class="btn-back" onclick="nav(2,'back')">← Retour</button>
  <div class="app-title" style="font-size:1.5rem; margin-bottom:16px;">Paramètres</div>

  <div class="section-lbl">Niveau de difficulté</div>
  <div class="level-row">
    <div class="lvl-card" data-lv="1" onclick="selectLevel(1)">
      <div class="lvl-icon">🌱</div>
      <div class="lvl-name">Débutant</div>
    </div>
    <div class="lvl-card" data-lv="2" onclick="selectLevel(2)">
      <div class="lvl-icon">⭐</div>
      <div class="lvl-name">Intermédiaire</div>
    </div>
    <div class="lvl-card" data-lv="3" onclick="selectLevel(3)">
      <div class="lvl-icon">🔥</div>
      <div class="lvl-name">Confirmé</div>
    </div>
    <div class="lvl-card" data-lv="4" onclick="selectLevel(4)">
      <div class="lvl-icon">🏆</div>
      <div class="lvl-name">Expert</div>
    </div>
  </div>

  <div class="settings-box">
    <div class="settings-row">
      <div class="settings-label">⏱ Durée par question</div>
      <div class="chip-row" id="timeChips">
        <button class="chip-btn" onclick="setTime(5)">5 s</button>
        <button class="chip-btn selected" onclick="setTime(10)">10 s</button>
        <button class="chip-btn" onclick="setTime(20)">20 s</button>
        <button class="chip-btn" onclick="setTime(30)">30 s</button>
        <button class="chip-btn" onclick="setTime(45)">45 s</button>
        <button class="chip-btn" onclick="setTime(60)">1 min</button>
        <button class="chip-btn" onclick="setTime(75)">1 min 15</button>
        <button class="chip-btn" onclick="setTime(90)">1 min 30</button>
      </div>
      <div class="custom-row">
        <label>Autre :</label>
        <input type="number" id="customTime" min="3" max="120" placeholder="sec" onchange="setCustomTime(this.value)">
        <label>s</label>
      </div>
    </div>
    <div class="settings-row">
      <div class="settings-label">📝 Nombre de questions</div>
      <div class="chip-row" id="nbChips">
        <button class="chip-btn" onclick="setNbQ(5)">5</button>
        <button class="chip-btn selected" onclick="setNbQ(10)">10</button>
        <button class="chip-btn" onclick="setNbQ(15)">15</button>
        <button class="chip-btn" onclick="setNbQ(20)">20</button>
        <button class="chip-btn" onclick="setNbQ(30)">30</button>
      </div>
    </div>
  </div>

  <button class="btn btn-primary" id="startBtn" onclick="startGame()">▶ Commencer !</button>
</div>

<!-- ====================================================
     ÉCRAN 4 : JEU
===================================================== -->
<div class="screen" id="s4">
  <div class="game-header">
    <div class="g-chip" id="gCatLabel">Addition</div>
    <div class="g-chip">Q <span id="gQNum">1</span>/<span id="gQTotal">10</span></div>
    <div class="g-chip">✅ <span id="gScore">0</span></div>
    <div class="g-chip" id="gLvLabel">Débutant</div>
  </div>
  <div class="progress-bar"><div class="progress-fill" id="progressFill" style="width:0%"></div></div>

  <div class="timer-wrap">
    <svg class="timer-svg" width="96" height="96" viewBox="0 0 96 96">
      <circle class="timer-bg" cx="48" cy="48" r="41"/>
      <circle class="timer-arc" id="timerArc" cx="48" cy="48" r="41"
        stroke-dasharray="257.6" stroke-dashoffset="0" stroke="var(--accent4)"/>
    </svg>
    <div class="timer-text" id="timerText">10</div>
  </div>

  <div class="question-card">
    <div class="question-label" id="qLabel">Question 1</div>
    <div class="question-text" id="qText">?</div>
    <div class="question-hint" id="qHint"></div>
  </div>

  <div id="normalAnswer">
    <div class="answer-wrap">
      <input type="text" inputmode="decimal" class="answer-input" id="answerInput"
        placeholder="?" autocomplete="off" onkeydown="handleKey(event)">
    </div>
  </div>

  <div id="dualAnswer" style="display:none;">
    <div class="dual-answer">
      <div>
        <div class="dual-label">Quotient</div>
        <input type="text" inputmode="numeric" class="answer-input" id="ansQ"
          placeholder="?" autocomplete="off" onkeydown="handleKeyDual(event,'q')">
      </div>
      <div>
        <div class="dual-label">Reste</div>
        <input type="text" inputmode="numeric" class="answer-input" id="ansR"
          placeholder="?" autocomplete="off" onkeydown="handleKeyDual(event,'r')">
      </div>
    </div>
  </div>

